{
  "compilerOptions": {
    "target": "ES2021",
    "module": "CommonJS",
    "moduleResolution": "node",
    "outDir": "dist/server",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "declaration": false,
    "jsx": "react-jsx",
    "paths": {
      "@/*": ["./*"]
    }
  },
  "include": ["server.ts", "server/**/*.ts", "shared/**/*.ts", "auth/**/*.ts", "workflows/**/*.ts", "__tests__/**/*.ts", "__tests__/**/*.tsx"]
}
