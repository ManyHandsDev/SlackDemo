// prisma/schema.prisma
//
// Source of truth for the database schema.
// After editing this file, run:
//   npm run db:generate  — regenerates the Prisma client
//   npm run db:push      — pushes schema to database (dev)
//   npm run db:migrate   — creates a migration and applies it (production)
//
// Conventions:
//   - All IDs are cuid strings (auto-generated by Prisma @default(cuid()))
//   - Soft deletes use a nullable deletedAt timestamp + isDeleted boolean
//   - Timestamps: createdAt (@default(now())), updatedAt (@updatedAt)
//   - Enum-like fields use String type (SQLite has no native enum support).
//     Valid values are enforced at the application layer via TypeScript enums
//     in shared/types/index.ts.
//
// NOTE: This schema uses SQLite for local development.
// For production, switch the provider to "postgresql" and:
//   - Convert String enum fields to native PostgreSQL enums
//   - Add full-text search via tsvector/GIN index on messages.content_plain
//   - Add @db.Text annotations on large text fields (Account tokens, etc.)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Auth.js / NextAuth v5 required tables
// ---------------------------------------------------------------------------

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?

  // Profile fields (beyond NextAuth defaults)
  title       String?
  statusText  String?
  statusEmoji String?
  timezone    String?

  // NEW: Do Not Disturb expiration timestamp
  dndUntil DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Auth.js relations
  accounts Account[]
  sessions Session[]

  // Domain relations (existing)
  ownedWorkspaces      Workspace[]       @relation("WorkspaceOwner")
  workspaceMemberships WorkspaceMember[]
  channelMemberships   ChannelMember[]
  createdChannels      Channel[]         @relation("ChannelCreator")
  messages             Message[]
  reactions            Reaction[]
  files                FileAttachment[]
  pins                 Pin[]             @relation("PinnedBy")
  bookmarks            Bookmark[]
  notifications        Notification[]
  sentNotifications    Notification[]    @relation("NotificationActor")
  customEmojis         CustomEmoji[]     @relation("EmojiCreator")

  // NEW relations
  pollVotes         PollVote[]          @relation("PollVotes")
  canvasVersions    CanvasVersion[]
  createdCanvases   Canvas[]
  scheduledMessages ScheduledMessage[]  @relation("ScheduledMessages")
  callsInitiated    Call[]              @relation("CallsInitiated")
  callParticipants  CallParticipant[]
  channelCategories ChannelCategory[]   @relation("ChannelCategories")
  workflowsCreated  Workflow[]          @relation("WorkflowsCreated")
  auditLogs         AuditLog[]          @relation("AuditLogs")

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ---------------------------------------------------------------------------
// Workspace
// ---------------------------------------------------------------------------

model Workspace {
  id      String  @id @default(cuid())
  name    String
  slug    String  @unique
  iconUrl String?
  ownerId String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  owner        User              @relation("WorkspaceOwner", fields: [ownerId], references: [id])
  members      WorkspaceMember[]
  channels     Channel[]
  customEmojis CustomEmoji[]

  // NEW relations
  workflows   Workflow[]
  auditLogs   AuditLog[]

  @@map("workspaces")
}

// Role values: OWNER | ADMIN | MEMBER
// Enforced by MemberRole enum in shared/types/index.ts

model WorkspaceMember {
  id          String   @id @default(cuid())
  workspaceId String
  userId      String
  role        String   @default("MEMBER")
  joinedAt    DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@index([workspaceId])
  @@index([userId])
  @@map("workspace_members")
}

// ---------------------------------------------------------------------------
// Channels
// ---------------------------------------------------------------------------

// ChannelType values: PUBLIC | PRIVATE | DM | GROUP_DM
// Enforced by ChannelType enum in shared/types/index.ts

model Channel {
  id          String  @id @default(cuid())
  workspaceId String
  name        String
  description String?
  type        String  @default("PUBLIC")
  isArchived  Boolean @default(false)
  createdById String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workspace Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdBy User            @relation("ChannelCreator", fields: [createdById], references: [id])
  members   ChannelMember[]
  messages  Message[]
  pins      Pin[]

  // NEW relations
  canvas            Canvas[]
  calls             Call[]
  scheduledMessages ScheduledMessage[]
  channelCategories ChannelCategory[]

  @@unique([workspaceId, name])
  @@index([workspaceId])
  @@map("channels")
}

// NotifyPref values: ALL | MENTIONS | NOTHING | DEFAULT
// Enforced at application layer

model ChannelMember {
  id         String    @id @default(cuid())
  channelId  String
  userId     String
  lastReadAt DateTime?
  notifyPref String    @default("DEFAULT")
  joinedAt   DateTime  @default(now())

  channel Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([channelId, userId])
  @@index([channelId])
  @@index([userId])
  @@map("channel_members")
}

// ---------------------------------------------------------------------------
// Messages
// ---------------------------------------------------------------------------

model Message {
  id        String @id @default(cuid())
  channelId String
  userId    String

  /// Tiptap JSON document stored as JSON text
  contentJson String

  /// Stripped plain text for search and notification previews.
  /// Production: use PostgreSQL tsvector + GIN index for full-text search.
  contentPlain String

  /// Non-null when this is a thread reply
  parentId   String?
  replyCount Int     @default(0)

  isEdited  Boolean   @default(false)
  isDeleted Boolean   @default(false)
  editedAt  DateTime?
  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  channel  Channel   @relation(fields: [channelId], references: [id], onDelete: Cascade)
  author   User      @relation(fields: [userId], references: [id])
  parent   Message?  @relation("ThreadReplies", fields: [parentId], references: [id])
  replies  Message[] @relation("ThreadReplies")

  reactions Reaction[]
  files     FileAttachment[]
  pins      Pin[]
  bookmarks Bookmark[]

  // NEW relations
  poll         Poll?
  linkPreviews LinkPreview[]

  @@index([channelId, createdAt(sort: Desc)])
  @@index([parentId])
  @@index([userId])
  @@map("messages")
}

// ---------------------------------------------------------------------------
// Reactions
// ---------------------------------------------------------------------------

model Reaction {
  id        String @id @default(cuid())
  messageId String
  userId    String
  emoji     String

  createdAt DateTime @default(now())

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  /// A user can only add each emoji once per message
  @@unique([userId, messageId, emoji])
  @@index([messageId])
  @@map("reactions")
}

// ---------------------------------------------------------------------------
// File Attachments
// ---------------------------------------------------------------------------

model FileAttachment {
  id        String  @id @default(cuid())
  messageId String?
  userId    String
  name      String
  mimeType  String
  size      Int
  url       String
  width     Int?
  height    Int?

  createdAt DateTime @default(now())

  message Message? @relation(fields: [messageId], references: [id], onDelete: SetNull)
  user    User     @relation(fields: [userId], references: [id])

  @@index([messageId])
  @@index([userId])
  @@map("files")
}

// ---------------------------------------------------------------------------
// Pins
// ---------------------------------------------------------------------------

model Pin {
  id         String @id @default(cuid())
  channelId  String
  messageId  String @unique
  pinnedById String

  pinnedAt DateTime @default(now())

  channel  Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  message  Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  pinnedBy User    @relation("PinnedBy", fields: [pinnedById], references: [id])

  @@index([channelId])
  @@map("pins")
}

// ---------------------------------------------------------------------------
// Bookmarks
// ---------------------------------------------------------------------------

model Bookmark {
  id        String @id @default(cuid())
  messageId String
  userId    String
  position  Int    @default(0)

  createdAt DateTime @default(now())

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId])
  @@index([userId])
  @@map("bookmarks")
}

// ---------------------------------------------------------------------------
// Notifications
// ---------------------------------------------------------------------------

// NotificationType values: MENTION | DM | THREAD_REPLY | REACTION
// Enforced by NotificationType enum in shared/types/index.ts

model Notification {
  id      String @id @default(cuid())
  userId  String
  actorId String?
  type    String

  /// JSON payload — shape defined in shared/types NotificationPayload union
  payload String

  readAt    DateTime?
  createdAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  actor User? @relation("NotificationActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([userId, readAt])
  @@index([userId, createdAt(sort: Desc)])
  @@map("notifications")
}

// ---------------------------------------------------------------------------
// Custom Emoji
// ---------------------------------------------------------------------------

model CustomEmoji {
  id          String @id @default(cuid())
  workspaceId String
  name        String
  imageUrl    String
  createdById String

  createdAt DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdBy User      @relation("EmojiCreator", fields: [createdById], references: [id])

  @@unique([workspaceId, name])
  @@index([workspaceId])
  @@map("custom_emojis")
}

// ---------------------------------------------------------------------------
// Scheduled Messages
// ---------------------------------------------------------------------------

model ScheduledMessage {
  id           String   @id @default(cuid())
  channelId    String
  userId       String
  contentJson  String
  contentPlain String
  scheduledFor DateTime
  sentAt       DateTime?
  isCancelled  Boolean  @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  channel Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  user    User    @relation("ScheduledMessages", fields: [userId], references: [id], onDelete: Cascade)

  /// Composite index for the cron job: find unsent, uncancelled messages due now
  @@index([scheduledFor, sentAt])
  @@index([channelId])
  @@index([userId])
  @@map("scheduled_messages")
}

// ---------------------------------------------------------------------------
// Polls
// ---------------------------------------------------------------------------

model Poll {
  id          String   @id @default(cuid())
  messageId   String   @unique
  question    String
  /// JSON array of option strings: ["Option 1", "Option 2", ...]
  options     String
  isActive    Boolean  @default(true)
  /// When true, voters may select more than one option
  multiChoice Boolean  @default(false)
  endsAt      DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  message Message    @relation(fields: [messageId], references: [id], onDelete: Cascade)
  votes   PollVote[]

  @@index([messageId])
  @@index([isActive, endsAt])
  @@map("polls")
}

model PollVote {
  id     String @id @default(cuid())
  pollId String
  userId String
  /// The selected option value from Poll.options
  option String

  votedAt DateTime @default(now())

  poll Poll @relation(fields: [pollId], references: [id], onDelete: Cascade)
  user User @relation("PollVotes", fields: [userId], references: [id], onDelete: Cascade)

  /// A user can only vote once per option per poll
  @@unique([pollId, userId, option])
  @@index([pollId])
  @@index([userId])
  @@map("poll_votes")
}

// ---------------------------------------------------------------------------
// Link Previews
// ---------------------------------------------------------------------------

model LinkPreview {
  id          String  @id @default(cuid())
  messageId   String?
  url         String
  title       String?
  description String?
  imageUrl    String?
  domain      String

  createdAt DateTime @default(now())

  message Message? @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([messageId])
  @@index([url])
  @@index([domain])
  @@map("link_previews")
}

// ---------------------------------------------------------------------------
// Canvas (Collaborative Documents)
// ---------------------------------------------------------------------------

model Canvas {
  id          String  @id @default(cuid())
  channelId   String
  name        String
  /// Tiptap/Yjs document serialized as JSON string
  contentJson String
  createdById String
  isActive    Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  channel   Channel         @relation(fields: [channelId], references: [id], onDelete: Cascade)
  createdBy User            @relation(fields: [createdById], references: [id])
  versions  CanvasVersion[]

  @@unique([channelId, name])
  @@index([channelId])
  @@index([createdById])
  @@map("canvas")
}

model CanvasVersion {
  id                String  @id @default(cuid())
  canvasId          String
  userId            String
  /// Full content snapshot at this version
  contentJson       String
  changeDescription String?

  createdAt DateTime @default(now())

  canvas Canvas @relation(fields: [canvasId], references: [id], onDelete: Cascade)
  editor User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([canvasId, createdAt(sort: Desc)])
  @@index([userId])
  @@map("canvas_versions")
}

// ---------------------------------------------------------------------------
// Voice/Video Calls
// ---------------------------------------------------------------------------

model Call {
  id          String    @id @default(cuid())
  channelId   String
  initiatorId String
  startedAt   DateTime  @default(now())
  endedAt     DateTime?
  /// Duration in seconds
  duration    Int?

  channel      Channel          @relation(fields: [channelId], references: [id], onDelete: Cascade)
  initiator    User             @relation("CallsInitiated", fields: [initiatorId], references: [id])
  participants CallParticipant[]

  @@index([channelId, startedAt(sort: Desc)])
  @@index([initiatorId])
  @@map("calls")
}

model CallParticipant {
  id       String    @id @default(cuid())
  callId   String
  userId   String
  joinedAt DateTime  @default(now())
  leftAt   DateTime?

  call Call @relation(fields: [callId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([callId, userId])
  @@index([callId])
  @@index([userId])
  @@map("call_participants")
}

// ---------------------------------------------------------------------------
// Channel Categories (per-user channel organization)
// ---------------------------------------------------------------------------

model ChannelCategory {
  id           String @id @default(cuid())
  channelId    String
  userId       String
  categoryName String
  /// Position within the category list for ordering
  position     Int    @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  channel Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  user    User    @relation("ChannelCategories", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([channelId, userId])
  @@index([userId, position])
  @@index([channelId])
  @@map("channel_categories")
}

// ---------------------------------------------------------------------------
// Workflows (Automation)
// ---------------------------------------------------------------------------

// WorkflowTriggerType values: message_posted | member_joined | reaction_added | scheduled
// WorkflowActionType values: post_message | send_notification | add_reaction | assign_role

model Workflow {
  id          String  @id @default(cuid())
  workspaceId String
  name        String
  description String?
  enabled     Boolean @default(true)
  /// Trigger type: 'message_posted' | 'member_joined' | 'reaction_added' | 'scheduled'
  triggerType String
  /// JSON object — trigger-specific configuration
  triggerConfig String
  createdById String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workspace  Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdBy  User                @relation("WorkflowsCreated", fields: [createdById], references: [id])
  actions    WorkflowAction[]
  executions WorkflowExecution[]

  @@index([workspaceId])
  @@index([createdById])
  @@map("workflows")
}

model WorkflowAction {
  id         String @id @default(cuid())
  workflowId String
  /// Execution order (0-based)
  sequence   Int
  /// Action type: 'post_message' | 'send_notification' | 'add_reaction' | 'assign_role'
  actionType String
  /// JSON object — action-specific configuration
  config     String

  createdAt DateTime @default(now())

  workflow Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@index([workflowId])
  @@map("workflow_actions")
}

model WorkflowExecution {
  id          String @id @default(cuid())
  workflowId  String
  /// Event type that triggered this execution
  triggeredBy String
  /// 'success' | 'failed' | 'partial'
  status      String @default("success")
  /// Error message if status is 'failed'
  error       String?

  executedAt DateTime @default(now())

  workflow Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@index([workflowId, executedAt(sort: Desc)])
  @@map("workflow_executions")
}

// ---------------------------------------------------------------------------
// Audit Log
// ---------------------------------------------------------------------------

model AuditLog {
  id          String  @id @default(cuid())
  workspaceId String
  actorId     String
  /// Action identifier, e.g. 'MEMBER_ROLE_CHANGED', 'MEMBER_REMOVED', 'CHANNEL_ARCHIVED'
  action      String
  /// ID of the affected resource
  targetId    String?
  /// JSON object: key-value changes, e.g. { role: { from: 'MEMBER', to: 'ADMIN' } }
  changes     String?

  createdAt DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  actor     User      @relation("AuditLogs", fields: [actorId], references: [id])

  @@index([workspaceId, createdAt(sort: Desc)])
  @@index([actorId])
  @@map("audit_logs")
}
