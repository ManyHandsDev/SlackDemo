# ============================================================================
# Slack Clone — Environment Variables
# ============================================================================
# Copy this file to .env and fill in the values:
#   cp .env.example .env
#
# Required vars are marked with (REQUIRED). The app will not start without them.
# ============================================================================

# Database (REQUIRED)
# SQLite for local development:
DATABASE_URL="file:./dev.db"
# PostgreSQL for production:
# DATABASE_URL="postgresql://user:password@localhost:5432/slack_clone"

# Auth — NextAuth v5 / Auth.js (REQUIRED)
# Generate with: openssl rand -hex 32
AUTH_SECRET=""
AUTH_URL="http://localhost:3000"

# OAuth providers (configure at least one for login)
AUTH_GITHUB_ID=""
AUTH_GITHUB_SECRET=""
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# File storage — local development
UPLOAD_DIR="./public/uploads"
NEXT_PUBLIC_UPLOAD_BASE_URL="http://localhost:3000/uploads"

# File storage — production (S3)
# AWS_ACCESS_KEY_ID=""
# AWS_SECRET_ACCESS_KEY=""
# AWS_REGION="us-east-1"
# AWS_S3_BUCKET=""

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
PORT=3000
NODE_ENV=development

# GIF search — Tenor API v2 (optional — GIF button is hidden if unset)
# Get a free key at: https://developers.google.com/tenor/guides/quickstart
TENOR_API_KEY=""

# TURN server — required for cross-network voice/video calls (optional)
# Without a TURN server, calls only work on the same LAN / non-symmetric NAT.
# Install coturn: sudo apt install coturn
# See startup.sh for a quick coturn setup guide.
NEXT_PUBLIC_TURN_URL=""
NEXT_PUBLIC_TURN_USERNAME=""
NEXT_PUBLIC_TURN_CREDENTIAL=""

# Demo mode — set to "true" to enable public demo lockdown:
# - Users pick a display name to join (no email/password registration)
# - File uploads, workspace/channel creation, custom emojis disabled
# - GIF picker hidden
# - Unauthenticated users redirected to name picker instead of login
DEMO_MODE=false
NEXT_PUBLIC_DEMO_MODE=false
