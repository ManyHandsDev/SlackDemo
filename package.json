  "name": "slack-clone",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch server.ts",
    "build": "next build && tsup server.ts --format cjs --out-dir dist/server",
    "start": "NODE_ENV=production node dist/server/server.js",
